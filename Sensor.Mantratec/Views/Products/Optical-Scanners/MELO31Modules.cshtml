<!-- Begin Slider -->
<section class="product_poster_section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-xl-5 col-lg-7 col-md-6 col-sm-12 col-xs-12">
                <img class="img-fluid" src="@Url.Content("~/Assets/Images/Modules/MELO31/MELO31.png")" alt="MELO31 Optical Fingerprint Module Scanner" title="MELO31 Optical Fingerprint Module Scanner" />
            </div>
            <div class="col-xl-7 col-lg-5 col-md-6 col-sm-12 col-xs-12">
                <h1>
                    MELO31
                    <br />Optical Fingerprint Scanner
                </h1>
                <p>Model : MELO31 | OEM Module / Sensor : MELv7.0</p>
                <div class="product_action_box">
                    <a href="#specification_section" class="action_box specification_section_click">
                        <i class="maicon_spcification"></i>
                        <p>Specification</p>
                    </a>
                    <a href="@Url.Content("/contact-us")" class="action_box">
                        <i class="maicon_inquiry"></i>
                        <p>Inquiry</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- End Slider -->
<!-- Begin Hardware Features -->
<section class="features_section">
