<!-- Begin Slider -->
<section class="product_poster_section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-xl-5 col-lg-7 col-md-6 col-sm-12 col-xs-12">
                <img class="img-fluid" src="@Url.Content("~/Assets/Images/Modules/MARC10/MARC10-lg.png")" alt="MARC10 Slick Capacitive Fingerprint Scanner Module" title="MARC10 Slick Capacitive Fingerprint Scanner Module" />
            </div>
            <div class="col-xl-7 col-lg-5 col-md-6 col-sm-12 col-xs-12">
                <h1>
                    MARC10
                    <br />Slick Capacitive Fingerprint Scanner
                </h1>
                <p>Model : MARC10 | OEM Module / Sensor : MOPvC10</p>
                <div class="product_action_box">
                    <a href="@Url.Content("~/Assets/Images/Modules/MARC10/MARC10-Module.pdf")" class="action_box" download>
                        <i class="maicon_brochure"></i>
                        <p>Brochure</p>
                    </a>
                    <a href="#specification_section" class="action_box specification_section_click">
                        <i class="maicon_spcification"></i>
                        <p>Specification</p>
                    </a>
                    <a href="@Url.Content("/contact-us")" class="action_box">
                        <i class="maicon_inquiry"></i>
                        <p>Inquiry</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- End Slider -->
