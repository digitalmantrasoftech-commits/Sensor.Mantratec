@section bottom_allpages{

    <script src="@Url.Content("~/Assets/Plugin/Jquery-Core-3.7.1/jquery-3.7.1.min.js")"></script>
    <script>
        $(document).ready(function () {
            var offset = -100; // Negative offset value

            $('.table_of_content_box a[href^="#"]').on('click', function (event) {
                event.preventDefault(); // Prevent default anchor click behavior

                var target = this.hash; // Get the hash part (id) from the clicked link
                var $target = $(target); // Get the target div

                if ($target.length) { // Check if the target exists
                    $('html, body').animate({
                        scrollTop: $target.offset().top + offset
                    }, 200); // Adjust scroll speed if necessary
                }
            });
        });
    </script>
}




